generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id                String              @id @default(uuid())
  title             String
  description       String?
  type              RecipeType
  instagramURL      String?
  isCustom          Boolean             @default(false)
  isFavorite        Boolean             @default(false)
  thumbnailURL      String?
  healthStatus      RecipeHealthStatus? @default(NEEDS_IMPROVEMENT)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  clerkId           String
  recipeIngredients RecipeIngredient[]
  dailyMenus        DailyMenu[]         @relation("DailyMenuToRecipe")
  ingredients       Ingredient[]        @relation("IngredientToRecipe")

  recipeFeedbacks RecipeFeedback[]
}

model RecipeFeedback {
  id        String   @id @default(uuid())
  recipeId  String
  rating    Int // e.g. 1 to 5
  easiness  Int? // e.g. 1 to 5
  flavor    Int? // e.g. 1 to 5
  timeSpent Int? // e.g. 1 to 5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clerkId   String
  recipe    Recipe   @relation(fields: [recipeId], references: [id])
}

model Ingredient {
  id                String             @id @default(uuid())
  name              String
  type              IngredientType?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  clerkId           String
  recipeIngredients RecipeIngredient[]
  recipes           Recipe[]           @relation("IngredientToRecipe")
}

model RecipeIngredient {
  recipeId     String
  ingredientId String
  quantity     String
  clerkId      String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  recipe       Recipe     @relation(fields: [recipeId], references: [id])

  @@id([recipeId, ingredientId])
}

model DailyMenu {
  id          String       @id @default(uuid())
  date        DateTime
  cooked      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  clerkId     String
  recipes     Recipe[]     @relation("DailyMenuToRecipe")
  weeklyMenus WeeklyMenu[] @relation("DailyMenuToWeeklyMenu")
}

model WeeklyMenu {
  id        String      @id @default(uuid())
  week      Int
  year      Int
  label     String // e.g. "Week of Jan 1 to Jan 7"
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  clerkId   String
  recipes   DailyMenu[] @relation("DailyMenuToWeeklyMenu")
}

enum RecipeType {
  MEAT
  FISH
  VEGETARIAN
  DESSERT
  SNACK
}

enum RecipeHealthStatus {
  GOOD
  ALMOST
  NEEDS_IMPROVEMENT
}

enum IngredientType {
  Protein
  Carbs
  Legumes
  Vegetable
  Fruit
  FatsAndDairy
  Condiments
  ReadyMeals
}
