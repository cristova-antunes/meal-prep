generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id                String              @id @default(uuid())
  title             String
  description       String?
  type              RecipeType
  instagramURL      String?
  isCustom          Boolean             @default(false)
  isFavorite        Boolean             @default(false)
  thumbnailURL      String?
  healthStatus      RecipeHealthStatus? @default(NEEDS_IMPROVEMENT)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  clerkId           String
  recipeIngredients RecipeIngredient[]
  dailyMenus        DailyMenu[]         @relation("DailyMenuToRecipe")
  ingredients       Ingredient[]        @relation("IngredientToRecipe")

  recipeFeedbacks RecipeFeedback[]

  groceryItems GroceryItem[] @relation("GroceryItemToRecipe")
}

model RecipeFeedback {
  id        String   @id @default(uuid())
  recipeId  String
  rating    Int // e.g. 1 to 5
  easiness  Int? // e.g. 1 to 5
  flavor    Int? // e.g. 1 to 5
  timeSpent String?
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clerkId   String
  recipe    Recipe   @relation(fields: [recipeId], references: [id])
}

model Ingredient {
  id                String             @id @default(uuid())
  name              String
  type              IngredientType?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  clerkId           String
  recipeIngredients RecipeIngredient[]
  recipes           Recipe[]           @relation("IngredientToRecipe")

  groceryItems GroceryItem[]
}

model RecipeIngredient {
  recipeId     String
  ingredientId String
  quantity     String
  clerkId      String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  recipe       Recipe     @relation(fields: [recipeId], references: [id])

  @@id([recipeId, ingredientId])
}

model DailyMenu {
  id          String       @id @default(uuid())
  date        DateTime
  cooked      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  clerkId     String
  recipes     Recipe[]     @relation("DailyMenuToRecipe")
  weeklyMenus WeeklyMenu[] @relation("DailyMenuToWeeklyMenu")
}

model WeeklyMenu {
  id        String      @id @default(uuid())
  week      Int
  year      Int
  label     String // e.g. "Week of Jan 1 to Jan 7"
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  clerkId   String
  recipes   DailyMenu[] @relation("DailyMenuToWeeklyMenu")
}

model GroceryItem {
  id        String   @id @default(uuid())
  clerkId   String // Keeps it isolated per user
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 1. For Auto-Generated Items (Linked to your Master Ingredients)
  ingredientId String?     @unique // Unique per user so an ingredient only appears ONCE
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  // 2. For Manual Entries (When you type "Paper Towels" or "Milk")
  customName String?
  customType IngredientType? // Allows sorting manual items by category too!

  // 3. State Management
  quantity    Int     @default(1) // "I need 2 blocks of Tofu"
  isCompleted Boolean @default(false) // For the "cross-off" UX

  // 4. Traceability (The magic connector)
  recipes Recipe[] @relation("GroceryItemToRecipe")
}

enum RecipeType {
  MEAT
  FISH
  VEGETARIAN
  DESSERT
  SNACK
  BREAKFAST
  PRE_WORKOUT
}

enum RecipeHealthStatus {
  GOOD
  ALMOST
  NEEDS_IMPROVEMENT
}

enum IngredientType {
  Protein
  Carbs
  Legumes
  Vegetable
  Fruit
  FatsAndDairy
  Condiments
  ReadyMeals
}
